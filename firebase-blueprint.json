{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and productivity stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "productivityScore": { "type": "number" },
        "totalStudyHours": { "type": "number" },
        "totalCompletedTasks": { "type": "number" },
        "streak": { "type": "number" },
        "lastActiveDate": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Study Task",
      "description": "A daily study task",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "goalId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "duration": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "status", "date"]
    },
    "Goal": {
      "title": "Long Term Goal",
      "description": "A long-term study goal with start/end dates",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "progress": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "startDate", "endDate", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "The user document"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Study tasks"
    },
    "goals/{goalId}": {
      "schema": "Goal",
      "description": "Long term study goals"
    }
  }
}
